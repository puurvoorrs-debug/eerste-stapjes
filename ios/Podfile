# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# CocoaPods analytics sends usage stats.
# cocoapods-stats is not always installed.
# if Gem::Specification::find_all_by_name('cocoapods-stats').any?
#   plugin 'cocoapods-stats'
# end

# CocoaPods local specs
install! 'cocoapods', :disable_input_output_paths => true

def flutter_install_all_ios_pods(ios_application_path = nil)
  # This is the standard flutter helper that dynamically imports all plugins.
  # On macOS, cocoapods looks at the helper ruby scripts inside flutter tools.
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '14.0'
    end
  end
end
